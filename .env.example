## Core
SUITE_WEB_ENV=dev
SUITE_WEB_HOST=127.0.0.1
SUITE_WEB_PORT=8080
SUITE_WEB_RELOAD=1

## Secrets
# Session cookie signing secret (set to a long random string in prod)
SUITE_WEB_SESSION_SECRET=change-me

# Master key used to encrypt API keys at rest.
# Recommended: output of `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
SUITE_WEB_MASTER_KEY=

## DB
SUITE_WEB_DB_URL=sqlite:///$HOME/ai-testbed-suite/suite_web.sqlite3

## Paths (optional; $HOME expanded when .env is sourced)
SUITE_WEB_ARTIFACTS_DIR=$HOME/ai-testbed-suite/suite_web/artifacts
SUITE_WEB_CUSTOM_PROBES_DIR=$HOME/ai-testbed-suite/suite_web/custom_probes
SUITE_WEB_CUSTOM_AUGUSTUS_TEMPLATES_DIR=$HOME/ai-testbed-suite/suite_web/custom_augustus_templates

## Tool roots (optional; defaults to repo folders)
SUITE_WEB_AUGUSTUS_DIR=$HOME/ai-testbed-suite/augustus-local-llm-openai
SUITE_WEB_AGENTDOJO_DIR=$HOME/ai-testbed-suite/agentdojo-quickstart
SUITE_WEB_LOCALGUARD_DIR=$HOME/ai-testbed-suite/LocalGuard

## LocalGuard judge (OpenAI-compat): API key sent when judge profile has none.
## If your model server validates the key and rejects "sk-local", set this to the value it accepts,
## or turn off API key validation in the server (LM Studio / vLLM / etc.).
# SUITE_WEB_LOCALGUARD_OPENAI_API_KEY=your-server-accepted-key

## Optional: compiled augustus binary
# SUITE_WEB_AUGUSTUS_BIN=/path/to/augustus

## Bootstrap first admin (recommended for non-dev)
SUITE_WEB_BOOTSTRAP_ADMIN_USERNAME=admin
SUITE_WEB_BOOTSTRAP_ADMIN_PASSWORD=admin

## Security toggles
# Allow admin-only custom-probe raw code editor (disabled by default)
SUITE_WEB_ALLOW_ADMIN_PROBE_CODE=0
